var a = "global a";
var b = "global b";
var c = "global c";

{
    print "----------";
    var a = "outer a";
    var b = "outer b";
    print a;
    print b;
    print c;

    {
        print "----------";
        var a = "inner a";
        print a;
        print b;
        print c;
        print "----------";
    }

    print "----------";
}
print a;
print b;
print c;