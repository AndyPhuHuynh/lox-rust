fun GetFunc() {
    print "Getting function!";
    return PrintFib;
}

fun PrintFib(count) {
    var a = 1;
    var b = 1;
    var iter = 0;

    while (iter < count) {
        print a;
        var temp = b;
        b = a + b;
        a = temp;
        iter = iter + 1;
    }

    return "Fib completed!";
}

var ret = GetFunc()(10);
print ret;

return 56;
